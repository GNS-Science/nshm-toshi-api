  "devDependencies": {
    "serverless": "4.37.0",
    "serverless-dynamodb": "0.2.58",
    "serverless-plugin-ifelse": "^1.0.7",
    "serverless-plugin-warmup": "8.4.1",
    "serverless-s3-local": "^0.8.5"
  },
  "packageManager": "yarn@4.16.0",
  "resolutions": {
    "@hapi/content": "6.0.2",
    "@hapi/wreck": "18.1.2",
